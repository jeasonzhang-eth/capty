{
  "name": "capty",
  "version": "0.1.1",
  "description": "Real-time speech-to-text desktop app",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild --force",
    "sidecar": "cd sidecar && .venv/bin/capty-sidecar --port 8765",
    "build:sidecar": "cd sidecar && bash build.sh",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:all": "npm run build:sidecar && npm run dist",
    "e2e": "npm run build && playwright test",
    "e2e:debug": "npm run build && PWDEBUG=1 playwright test",
    "e2e:ui": "npm run build && playwright test --ui",
    "test": "ELECTRON_RUN_AS_NODE=true electron ./node_modules/vitest/vitest.mjs run",
    "test:watch": "ELECTRON_RUN_AS_NODE=true electron ./node_modules/vitest/vitest.mjs"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "dompurify": "^3.3.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-lrc": "^3.2.1",
    "wavesurfer.js": "^7.12.5",
    "zustand": "^4.5.0"
  }
}
