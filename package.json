{
  "name": "capty",
  "version": "0.1.0",
  "description": "Real-time speech-to-text desktop app",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild --force",
    "sidecar": "cd sidecar && .venv/bin/capty-sidecar --port 8765",
    "test": "npm rebuild better-sqlite3 && vitest run; EXIT=$?; electron-rebuild --force; exit $EXIT",
    "test:watch": "npm rebuild better-sqlite3 && vitest"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.8",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^11.0.0",
    "dompurify": "^3.3.3",
    "html-to-image": "^1.11.13",
    "marked": "^17.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-lrc": "^3.2.1",
    "wavesurfer.js": "^7.12.5",
    "zustand": "^4.5.0"
  }
}
